---
import { ClientRouter } from "astro:transitions";
import Navbar from "../components/navigations/Navbar.astro";
import Footer from "../sections/Home/Footer.astro";
import "../styles/global.css";
import { Font } from "astro:assets";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Shahabas Abdul Hameed | Portfolio",
  description = "Personal Portfolio of Shahabas Abdul Hameed",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <Font
      cssVariable="--font-heading"
      preload={[{ weight: 600, style: "normal" }]}
    />
    <Font
      cssVariable="--font-body"
      preload={[{ weight: 500, style: "normal" }]}
    />
    <Font cssVariable="--font-normal" />

    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>
