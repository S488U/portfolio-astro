---
import { twMerge } from "tailwind-merge";

interface Props {
  text: string;
  class?: string;
}

const { text, class: className = "" } = Astro.props;
---

<div class={twMerge("group relative inline-flex", className)}>
  <slot />

  <span
    class="pointer-events-none absolute bottom-full left-1/2 mb-2 origin-bottom -translate-x-1/2 translate-y-1 scale-75 rounded-md border border-border bg-card px-2.5 py-1 text-xs whitespace-nowrap text-foreground opacity-0 transition-all duration-200 group-hover:translate-y-0 group-hover:scale-100 group-hover:opacity-100"
  >
    {text}
  </span>
</div>
