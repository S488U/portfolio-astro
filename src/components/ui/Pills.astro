---
import { twMerge } from "tailwind-merge";

interface Props {
  tech: String;
  className?: string;
}

const { tech, className } = Astro.props;
---

<p
  class={twMerge(
    "transition-all cursor-default rounded-full border border-border bg-card/20 px-3 py-1 text-center text-[11px] text-foreground/80 select-none hover:scale-105 active:scale-100 sm:text-sm",
    className,
  )}
>
  {tech}
</p>
